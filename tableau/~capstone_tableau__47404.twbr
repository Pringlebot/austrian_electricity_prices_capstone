        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#9;&#9;&#9;&#9;&#9;&#9;&#9;&#9;&#13;&#10;WHEN    &quot;Price_Electricity&quot; THEN [Price_Electricity]&#13;&#10;WHEN&#9;&quot;Price_Gas&quot; THEN&#9;[Price_Gas]&#13;&#10;WHEN&#9;&quot;Price_Carbon&quot; THEN&#9;[Price_Carbon]&#13;&#10;WHEN&#9;&quot;Climate_CDD_Austria&quot; THEN&#9;[Climate_CDD_Austria]&#13;&#10;WHEN&#9;&quot;Climate_HDD_Austria&quot; THEN&#9;[Climate_HDD_Austria]&#13;&#10;WHEN&#9;&quot;Prod_Renewable_Pct&quot; THEN&#9;[Prod_Renewable_Pct]&#13;&#10;WHEN&#9;&quot;Prod_Renewable_Total&quot; THEN&#9;[Prod_Renewable_Total]&#13;&#10;WHEN&#9;&quot;prod_power_production_total&quot; THEN&#9;[prod_power_production_total]&#13;&#10;WHEN&#9;&quot;Prod_NonRenewable_Total&quot; THEN&#9;[Prod_NonRenewable_Total]&#13;&#10;WHEN&#9;&quot;Prod_Gross_Electricity&quot; THEN&#9;[Prod_Gross_Electricity]&#13;&#10;WHEN&#9;&quot;Prod_Gross_Consumption&quot; THEN&#9;[Prod_Gross_Consumption]&#13;&#10;WHEN&#9;&quot;Econ_Exports_Total&quot; THEN&#9;[Econ_Exports_Total]&#13;&#10;WHEN&#9;&quot;Econ_Imports_Energy&quot; THEN&#9;[Econ_Imports_Energy]&#13;&#10;END' />
      </column>
