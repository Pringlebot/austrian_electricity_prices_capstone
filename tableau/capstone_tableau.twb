        <calculation class='tableau' formula='IF ATTR([Calculation_2768587937368256514]) = &quot;Price Shock (2021-2023)&quot; THEN&#13;&#10;    WINDOW_AVG(SUM([Calculation_3335760015414497281])) + &#13;&#10;    (INDEX() - WINDOW_AVG(INDEX())) * &#13;&#10;    (WINDOW_COVARP(SUM([Calculation_3335760015414497281]), FLOAT(INDEX())) / WINDOW_VARP(FLOAT(INDEX())))&#13;&#10;ELSE NULL&#13;&#10;END'>
