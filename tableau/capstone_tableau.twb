    <worksheet name='Price_Deviations'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true'>Volatility Visualised</run>
            <run bold='true' fontcolor='#000000'>: Price Deviations from 1-Month Moving Average</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='data_tableau' name='federated.05za1gg1vj662t14t1a5n1depgm0' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column alias='Average value of EXAA Day Ahead + MC Auction (Austria)' caption='Select_Variable_1' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Price_Electricity&quot;'>
              <calculation class='tableau' formula='&quot;Price_Electricity&quot;' />
              <aliases>
                <alias key='&quot;Climate_CDD_Austria&quot;' value='Cooling Deegre Days Index (Austria)' />
                <alias key='&quot;Climate_HDD_Austria&quot;' value='Heating Deegre Days Index (Austria)' />
                <alias key='&quot;Econ_Exports_Total&quot;' value='Total Exports' />
                <alias key='&quot;Econ_Imports_Energy&quot;' value='Total Imports SITC-3 Fuels, Energy' />
                <alias key='&quot;Price_Carbon&quot;' value='Average Primary EU Carbon ETS Price' />
                <alias key='&quot;Price_Electricity&quot;' value='Average value of EXAA Day Ahead + MC Auction (Austria)' />
                <alias key='&quot;Price_Gas&quot;' value='Monthly indexed price of natural gas (Austria)' />
                <alias key='&quot;Prod_Gross_Consumption&quot;' value='Gross electricity consumption (domestic electricity consumption including consumption for pumped storage) (Austria)' />
                <alias key='&quot;Prod_Gross_Electricity&quot;' value='Gross electricity generation (public grid) (Austria)' />
                <alias key='&quot;Prod_NonRenewable_Total&quot;' value='Gross electricity generation from non renewable sources (thermal power plants using non-renewable fuels + other fuels)  (Austria)' />
                <alias key='&quot;prod_power_production_total&quot;' value='Gross electricity generation from all sources exkl. geothermal (Austria)' />
                <alias key='&quot;Prod_Renewable_Pct&quot;' value='Proportion of gross electricity generation from renewables in total gross electricity generation excl. geothermal (Austria)' />
                <alias key='&quot;Prod_Renewable_Total&quot;' value='Gross electricity generation from renewable sources (hydropower, biomass, wind, photovoltaics but NOT geothermal)  (Austria)' />
              </aliases>
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.05za1gg1vj662t14t1a5n1depgm0'>
            <column caption='VAR_Positive_Deviation' datatype='real' name='[Calculation_2768587937394548761]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([Calculation_3335760015414497281]) &gt; WINDOW_AVG(SUM([Calculation_3335760015414497281]), -11, 0)&#13;&#10;THEN SUM([Calculation_3335760015414497281])&#13;&#10;ELSE WINDOW_AVG(SUM([Calculation_3335760015414497281]), -11, 0)&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='VAR_Moving_Avg_12M' datatype='real' name='[Calculation_2768587937395544092]' role='measure' type='quantitative'>
