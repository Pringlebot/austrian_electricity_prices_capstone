      <column caption='Model_Time_Filter_Logic' datatype='boolean' name='[Calculation_2768587937645514823]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 5] = &quot;2015-2025&quot;&#13;&#10;OR&#13;&#10;([Parameters].[Parameter 5] = &quot;from 2020 only&quot; AND [Date] &gt;= #2020-01-01#)' />
