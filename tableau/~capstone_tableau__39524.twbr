              <calculation class='tableau' formula='IF SUM([Calculation_3335760015414497281]) &gt; WINDOW_AVG(SUM([Calculation_3335760015414497281]), -11, 0)&#13;&#10;THEN SUM([Calculation_3335760015414497281])&#13;&#10;ELSE WINDOW_AVG(SUM([Calculation_3335760015414497281]), -11, 0)&#13;&#10;END'>
