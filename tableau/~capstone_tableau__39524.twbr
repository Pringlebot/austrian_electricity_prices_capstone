            <column alias='Average value of EXAA Day Ahead + MC Auction (Austria) in EUR/MWh' caption='Select_Variable_1' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Price_Electricity&quot;'>
              <calculation class='tableau' formula='&quot;Price_Electricity&quot;' />
              <aliases>
