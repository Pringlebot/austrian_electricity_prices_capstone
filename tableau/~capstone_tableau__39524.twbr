      <column caption='Selected Model 1' datatype='real' name='[Calculation_2768587937640767554]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 3]&#13;&#10;    WHEN &quot;Price_Electricity&quot; THEN [Price_Electricity]&#13;&#10;    WHEN &quot;Pred_Persistence&quot; THEN [Pred_Persistence]&#13;&#10;    WHEN &quot;Pred_Seasonal_Naive&quot; THEN [Pred_Seasonal_Naive]&#13;&#10;    WHEN &quot;Pred_ARIMA_210&quot; THEN [Pred_ARIMA_210]&#13;&#10;    WHEN &quot;Pred_ARIMA_300&quot; THEN [Pred_ARIMA_300]&#13;&#10;    WHEN &quot;Pred_ARIMAX_301_Gas&quot; THEN [Pred_ARIMAX_301_Gas]&#13;&#10;    WHEN &quot;Pred_ARIMAX_000_Gas&quot; THEN [Pred_ARIMAX_000_Gas]&#13;&#10;END' />
