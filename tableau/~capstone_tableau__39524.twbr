        <calculation class='tableau' formula='IF [Period] = &quot;Stable Pre-Shock (2015-2020)&quot; THEN WINDOW_AVG(SUM([Calculation_3335760015414497281]), -11, 0)&#13;&#10;ELSEIF [Period] = &quot;Price Shock (2021-2023)&quot; THEN WINDOW_AVG(SUM([Calculation_3335760015414497281]), -11, 0)  &#13;&#10;ELSE WINDOW_AVG(SUM([Calculation_3335760015414497281]), -11, 0)&#13;&#10;END' />
